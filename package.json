{
  "name": "check-package-dependencies",
  "version": "11.1.1",
  "description": "Check package dependencies for duplicates, peer dependencies satisfaction and more early",
  "keywords": [
    "eslint",
    "eslintplugin",
    "package.json"
  ],
  "homepage": "https://github.com/christophehurpeau/check-package-dependencies",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (http://christophe.hurpeau.com/)",
  "repository": "https://github.com/christophehurpeau/check-package-dependencies.git",
  "bin": "./bin/check-package-dependencies.mjs",
  "files": [
    "src",
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index-node.mjs",
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/definitions/index.d.ts",
      "node": {
        "import": "./dist/index-node.mjs"
      }
    },
    "./eslint-plugin": {
      "types": "./dist/definitions/eslint-plugin.d.ts",
      "node": {
        "import": "./dist/eslint-plugin-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn clean:build && rollup --config rollup.config.mjs && yarn run build:definitions",
    "build:definitions": "tsc -p tsconfig.json",
    "checks": "node scripts/check-package.js",
    "clean": "yarn clean:build",
    "clean:build": "pob-esbuild-clean-out dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "generate:api": "typedoc --tsconfig tsconfig.doc.json",
    "generate:test-coverage": "rm -Rf docs/coverage/ ; NODE_ENV=production BABEL_ENV=test jest --coverage --coverageReporters=pob-lcov-reporter --coverageDirectory=docs/coverage/",
    "lint": "yarn run format && tsc && yarn run lint:eslint",
    "lint:eslint": "eslint --quiet .",
    "lint:eslint:package.json": "eslint --quiet package.json",
    "postinstall": "pob-root-postinstall",
    "postpack": "pinst --enable",
    "prepack": "pinst --disable",
    "test": "TZ=UTC node --import ./src/test-setup.ts --test src/**/*.test.ts",
    "test:coverage": "TZ=UTC npx c8 --all --src ./src node --import ./src/test-setup.ts --test src/**/*.test.ts",
    "test:coverage:json": "TZ=UTC npx c8 --reporter=json --all --src ./src node --import ./src/test-setup.ts --test src/**/*.test.ts",
    "test:watch": "TZ=UTC node --import ./src/test-setup.ts --test src/**/*.test.ts",
    "watch": "yarn clean:build && rollup --config rollup.config.mjs --watch"
  },
  "dependencies": {
    "@eslint/plugin-kit": "^0.7.1",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.8.0",
    "semver-utils": "^1.1.4",
    "type-fest": "^4.37.0 || ^5.1.0"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.4.3",
    "@pob/rollup-esbuild": "9.1.0",
    "@pob/root": "24.2.1",
    "@types/node": "24.10.4",
    "@types/semver": "7.7.1",
    "@types/semver-utils": "1.1.3",
    "eslint": "10.4.0",
    "pinst": "3.0.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.0.3"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "yarn@4.14.1",
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index",
      "eslint-plugin"
    ],
    "envs": [
      {
        "target": "node",
        "version": "22",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
